# Database — Railway sẽ tự tạo khi bạn add PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT Secret — đổi thành chuỗi bí mật riêng
JWT_SECRET="your-super-secret-jwt-key-change-this"

# MBBank Config
MBBANK_ACCOUNT=""
MBBANK_NAME="MB Bank"

# Deposit Config
MIN_DEPOSIT_AMOUNT="10000"
DEPOSIT_EXPIRY_MINUTES="15"

# Port (Railway sẽ tự set)
PORT=3000
