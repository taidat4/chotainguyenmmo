generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(cuid())
  username           String         @unique
  email              String         @unique
  passwordHash       String
  fullName           String
  avatarUrl          String?
  phone              String?
  role               Role           @default(USER)
  status             UserStatus     @default(ACTIVE)
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  lastLoginIp        String?
  twoFactorEnabled   Boolean        @default(false)
  twoFactorSecret    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  termsVersion       String?
  termsAcceptedAt    DateTime?
  termsAcceptedIp    String?
  termsAcceptedAgent String?
  auditLogs          AuditLog[]
  complaints         Complaint[]    @relation("BuyerComplaints")
  deposits           Deposit[]
  favorites          Favorite[]
  notifications      Notification[]
  orders             Order[]        @relation("BuyerOrders")
  reviews            Review[]
  shop               Shop?
  wallet             Wallet?
  withdrawals        Withdrawal[]
  invoices           Invoice[]

  @@index([username])
  @@index([email])
  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model Wallet {
  id               String              @id @default(cuid())
  userId           String              @unique
  availableBalance Int                 @default(0)
  heldBalance      Int                 @default(0)
  totalDeposited   Int                 @default(0)
  totalSpent       Int                 @default(0)
  totalRefunded    Int                 @default(0)
  totalWithdrawn   Int                 @default(0)
  currency         String              @default("VND")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id])
  transactions     WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id            String                @id @default(cuid())
  walletId      String
  type          WalletTransactionType
  direction     WalletDirection
  amount        Int
  balanceAfter  Int
  referenceType String?
  referenceId   String?
  description   String?
  note          String?
  createdAt     DateTime              @default(now())
  wallet        Wallet                @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model Shop {
  id                    String      @id @default(cuid())
  ownerId               String      @unique
  name                  String
  slug                  String      @unique
  logoUrl               String?
  bannerUrl             String?
  shortDescription      String?
  description           String?
  status                ShopStatus  @default(PENDING)
  verified              Boolean     @default(false)
  supportTimeText       String?
  responseRate          Float?      @default(0)
  ratingAverage         Float?      @default(0)
  ratingCount           Int         @default(0)
  successfulOrdersCount Int         @default(0)
  productCount          Int         @default(0)
  joinedAt              DateTime    @default(now())
  sellerTermsVersion    String?
  sellerTermsAcceptedAt DateTime?
  sellerTermsIp         String?
  sellerTermsAgent      String?
  legalName             String?
  taxCode               String?
  legalAddress          String?
  invoiceEmail          String?
  taxProfileStatus      String?     @default("incomplete")
  invoiceProfileStatus  String?     @default("incomplete")
  taxInvoiceEnabled     Boolean     @default(false)
  bankName              String?
  bankAccount           String?
  bankAccountName       String?
  bankBranch            String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  complaints            Complaint[] @relation("ShopComplaints")
  orders                Order[]     @relation("ShopOrders")
  products              Product[]
  owner                 User        @relation(fields: [ownerId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([ownerId])
}

model Category {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  icon         String?
  description  String?
  parentId     String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  productCount Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  parent       Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryChildren")
  products     Product[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id                   String           @id @default(cuid())
  shopId               String
  categoryId           String
  name                 String
  slug                 String           @unique
  shortDescription     String?
  description          String?
  price                Int
  compareAtPrice       Int?
  status               ProductStatus    @default(DRAFT)
  deliveryType         DeliveryType     @default(AUTO)
  warrantyPolicy       String?
  refundPolicy         String?
  supportPolicy        String?
  stockCountCached     Int              @default(0)
  soldCount            Int              @default(0)
  ratingAverage        Float?           @default(0)
  ratingCount          Int              @default(0)
  minPurchaseQty       Int              @default(1)
  maxPurchaseQty       Int              @default(10)
  isFeatured           Boolean          @default(false)
  isHot                Boolean          @default(false)
  isAutoDelivery       Boolean          @default(true)
  complaintWindowHours Int              @default(48)
  lastStockUpdateAt    DateTime?
  publishedAt          DateTime?
  approvedAt           DateTime?
  rejectionReason      String?
  metaTitle            String?
  metaDescription      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  adCampaigns          AdCampaign[]
  favorites            Favorite[]
  orderItems           OrderItem[]
  category             Category         @relation(fields: [categoryId], references: [id])
  shop                 Shop             @relation(fields: [shopId], references: [id])
  images               ProductImage[]
  tags                 ProductTagMap[]
  variants             ProductVariant[]
  reviews              Review[]
  stockBatches         StockBatch[]
  stockItems           StockItem[]

  @@index([slug])
  @@index([shopId])
  @@index([categoryId])
  @@index([status])
  @@index([price])
  @@index([soldCount])
  @@index([isFeatured])
  @@index([createdAt])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductTag {
  id       String          @id @default(cuid())
  name     String          @unique
  slug     String          @unique
  products ProductTagMap[]
}

model ProductTagMap {
  productId String
  tagId     String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model StockItem {
  id                String          @id @default(cuid())
  productId         String
  rawContent        String
  normalizedContent String?
  status            StockItemStatus @default(AVAILABLE)
  reservedAt        DateTime?
  soldAt            DateTime?
  orderId           String?
  uploadedBy        String?
  batchId           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  batch             StockBatch?     @relation(fields: [batchId], references: [id])
  product           Product         @relation(fields: [productId], references: [id])

  @@index([productId, status])
  @@index([orderId])
  @@index([batchId])
}

model StockBatch {
  id           String      @id @default(cuid())
  productId    String
  sourceType   String      @default("paste")
  fileName     String?
  totalLines   Int         @default(0)
  validLines   Int         @default(0)
  invalidLines Int         @default(0)
  notes        String?
  uploadedBy   String?
  createdAt    DateTime    @default(now())
  product      Product     @relation(fields: [productId], references: [id])
  items        StockItem[]

  @@index([productId])
}

model Order {
  id              String           @id @default(cuid())
  orderCode       String           @unique
  buyerId         String
  shopId          String
  status          OrderStatus      @default(PENDING)
  subtotal        Int              @default(0)
  discountAmount  Int              @default(0)
  feeAmount       Int              @default(0)
  totalAmount     Int              @default(0)
  paymentStatus   PaymentStatus    @default(PENDING)
  deliveryStatus  DeliveryStatus   @default(PENDING)
  complaintStatus ComplaintStatus?
  notes           String?
  paidAt          DateTime?
  deliveredAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  complaints      Complaint[]
  deliveries      Delivery[]
  buyer           User             @relation("BuyerOrders", fields: [buyerId], references: [id])
  shop            Shop             @relation("ShopOrders", fields: [shopId], references: [id])
  items           OrderItem[]
  invoices        Invoice[]

  @@index([orderCode])
  @@index([buyerId])
  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Int
  total     Int
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}
model Delivery {
  id        String         @id @default(cuid())
  orderId   String
  content   String?
  status    DeliveryStatus @default(PENDING)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  order     Order          @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Complaint {
  id             String             @id @default(cuid())
  complaintCode  String             @unique
  orderId        String
  buyerId        String
  shopId         String
  reason         ComplaintReason
  status         ComplaintStatus    @default(OPEN)
  priority       String?            @default("normal")
  summary        String
  adminDecision  String?
  resolutionType String?
  resolvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  buyer          User               @relation("BuyerComplaints", fields: [buyerId], references: [id])
  order          Order              @relation(fields: [orderId], references: [id])
  shop           Shop               @relation("ShopComplaints", fields: [shopId], references: [id])
  messages       ComplaintMessage[]

  @@index([complaintCode])
  @@index([orderId])
  @@index([buyerId])
  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

model ComplaintMessage {
  id          String    @id @default(cuid())
  complaintId String
  senderId    String
  senderRole  String
  message     String
  attachments String?
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@index([complaintId])
}

model Review {
  id        String       @id @default(cuid())
  productId String
  userId    String
  orderId   String?
  rating    Int
  comment   String?
  status    ReviewStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  product   Product      @relation(fields: [productId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([userId, orderId])
  @@index([productId])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
}



model Deposit {
  id              String        @id @default(cuid())
  userId          String
  amount          Int
  method          String
  status          DepositStatus @default(PENDING)
  proofUrl        String?
  referenceCode   String?       @unique
  transferContent String?
  bankTxnId       String?
  qrUrl           String?
  expiresAt       DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedReason  String?
  completedAt     DateTime?
  // ── USDT Payment Fields ──
  network         String?       // TRC20 | BEP20
  usdtAmount      Float?        // Expected USDT amount (with unique marker)
  usdtReceived    Float?        // Actual received USDT
  txHash          String?       // Blockchain transaction hash
  blockNumber     Int?          // Block number where tx was found
  confirmations   Int?          @default(0)
  senderAddress   String?       // Sender's wallet address
  detectedAt      DateTime?     // When transfer was first seen
  confirmedAt     DateTime?     // When enough confirmations reached
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([referenceCode])
  @@index([createdAt])
  @@index([method, status])
  @@index([network, usdtAmount, status])
  @@index([txHash])
}

// ── USDT Blockchain Event (idempotent, 1 row per on-chain transfer) ──
model UsdtTransferEvent {
  id              String   @id @default(cuid())
  network         String   // TRC20 | BEP20
  txHash          String
  logIndex        Int      @default(0)
  fromAddress     String
  toAddress       String
  amount          Float    // USDT amount
  tokenContract   String
  blockNumber     Int
  blockTimestamp  DateTime?
  depositId       String?  // Matched deposit (null if unmatched)
  matchStatus     String   @default("unmatched") // matched | unmatched | late | ignored
  processedAt     DateTime @default(now())

  @@unique([network, txHash, logIndex])
  @@index([toAddress, network])
  @@index([depositId])
  @@index([matchStatus])
}

// ── Watcher checkpoint (tracks last scanned block per network) ──
model UsdtScanCheckpoint {
  id              String   @id @default(cuid())
  network         String   @unique // TRC20 | BEP20
  lastBlock       Int      @default(0)
  lastScanAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Payment status audit log ──
model UsdtPaymentLog {
  id        String   @id @default(cuid())
  depositId String
  oldStatus String
  newStatus String
  reason    String?
  metadata  String?  // JSON: txHash, amount, etc.
  actor     String?  // system | admin:{userId}
  createdAt DateTime @default(now())

  @@index([depositId])
  @@index([createdAt])
}

model BankTransaction {
  id          String   @id
  userId      String?
  depositId   String?
  amount      Int
  bankTime    String?
  bankContent String?
  processedAt DateTime @default(now())

  @@index([userId])
  @@index([depositId])
}

model Withdrawal {
  id             String           @id @default(cuid())
  userId         String
  amount         Int
  feeAmount      Int              @default(0)
  netAmount      Int
  method         String           @default("bank_transfer")
  accountName    String?
  accountNumber  String?
  bankName       String?
  status         WithdrawalStatus @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  link      String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String?
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string")
  group String @default("general")

  @@index([key])
  @@index([group])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  targetId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model TermsAcceptance {
  id         String    @id @default(cuid())
  userId     String
  termsType  TermsType
  version    String
  acceptedAt DateTime  @default(now())
  acceptedIp String?
  userAgent  String?

  @@index([userId])
  @@index([termsType])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  name         String
  price        Int
  warrantyDays Int      @default(3)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isActive])
}

model Conversation {
  id            String                @id @default(cuid())
  participant1  String
  participant2  String
  status        ConversationStatus    @default(ACTIVE)
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  messages      ConversationMessage[]

  @@unique([participant1, participant2])
  @@index([participant1])
  @@index([participant2])
  @@index([updatedAt])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  attachments    String?
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model AdCampaign {
  id             String           @id @default(cuid())
  sellerId       String
  productId      String
  title          String
  status         AdCampaignStatus @default(DRAFT)
  bidAmount      Int
  totalBudget    Int
  dailyBudget    Int
  spentAmount    Int              @default(0)
  startDate      DateTime
  endDate        DateTime
  impressions    Int              @default(0)
  clicks         Int              @default(0)
  rejectedReason String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  product        Product          @relation(fields: [productId], references: [id])
  adImpressions  AdImpression[]

  @@index([sellerId])
  @@index([productId])
  @@index([status])
  @@index([startDate, endDate])
}

model AdImpression {
  id         String     @id @default(cuid())
  campaignId String
  type       String     @default("impression")
  cost       Int        @default(0)
  userId     String?
  createdAt  DateTime   @default(now())
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([createdAt])
}

enum Role {
  USER
  SELLER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum ShopStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  REJECTED
  OUT_OF_STOCK
  ARCHIVED
}

enum DeliveryType {
  AUTO
  MANUAL
}

enum WalletTransactionType {
  DEPOSIT
  PURCHASE
  SALE_EARNING
  REFUND
  WITHDRAWAL
  FEE
  ADJUSTMENT
}

enum WalletDirection {
  CREDIT
  DEBIT
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  DELIVERING
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
}

enum ComplaintStatus {
  OPEN
  SELLER_RESPONDED
  AWAITING_USER
  UNDER_REVIEW
  RESOLVED
  REJECTED
  REFUNDED
}

enum ComplaintReason {
  NOT_AS_DESCRIBED
  NOT_WORKING
  NOT_RECEIVED
  WRONG_ITEM
  DUPLICATE
  OTHER
}

enum ReviewStatus {
  ACTIVE
  HIDDEN
  FLAGGED
}

enum DepositStatus {
  PENDING
  PROCESSING
  DETECTED
  CONFIRMING
  CONFIRMED
  PARTIAL
  OVERPAID
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
  LATE_PAYMENT
  MANUAL_REVIEW
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum StockItemStatus {
  AVAILABLE
  RESERVED
  SOLD
  INVALID
}

enum TermsType {
  USER
  SELLER
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum AdCampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

// Vietnamese-law-compliant invoice (Hóa đơn điện tử theo TT78/2021/TT-BTC)
model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique // Format: HD-YYMMDD-XXXX
  orderId         String
  orderCode       String
  buyerId         String
  buyerName       String
  buyerEmail      String?
  sellerName      String        // Shop name
  sellerTaxCode   String?       // MST seller (nếu có)
  platformName    String        @default("ChoTaiNguyen")
  platformTaxCode String        @default("0123456789") // MST sàn

  // Amounts
  subtotal        Int           // Giá trước thuế
  vatRate         Int           @default(10) // % VAT
  vatAmount       Int           // Tiền thuế VAT
  feeAmount       Int           @default(0) // Phí sàn
  totalAmount     Int           // Tổng tiền sau thuế

  // Line items (JSON)
  items           String        // JSON: [{name, quantity, unitPrice, total}]

  // Status
  status          InvoiceStatus @default(ISSUED)
  issuedAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  order           Order         @relation(fields: [orderId], references: [id])
  buyer           User          @relation(fields: [buyerId], references: [id])

  @@index([orderId])
  @@index([buyerId])
  @@index([invoiceNumber])
  @@index([issuedAt])
}

enum InvoiceStatus {
  ISSUED
  CANCELLED
  ADJUSTED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum NotificationType {
  ORDER
  DEPOSIT
  DELIVERY
  SYSTEM
  COMPLAINT
  REVIEW
  WITHDRAWAL
}
